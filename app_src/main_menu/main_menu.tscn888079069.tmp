[ext_resource type="Theme" uid="uid://2pvmmwwojlrf" path="res://frontend/assets/button_theme.tres" id="2_67u13"]

[sub_resource type="GDScript" id="GDScript_06t4h"]
script/source = "extends Control

@onready var _button_aligner: BoxContainer = %ButtonAligner
const _BUTTON_THEME = preload(\"res://frontend/assets/button_theme.tres\")


func _ready() -> void:
	_setup_screen_resolution()
	_setup_menu_buttons()


## scale and center the game window on the user's monitor
func _setup_screen_resolution() -> void:
	# 1. Find the screen index the window is currently sitting on
	var current_screen: int = DisplayServer.window_get_current_screen()
	
	# 2. Get the actual total pixel resolution of that specific monitor
	var screen_size: Vector2i = DisplayServer.screen_get_size(current_screen)
	
	# 3. Calculate the new window size using your percentages
	var new_width: int = int(screen_size.x * GameManager.SCREEN_PERCENTAGE)
	var new_height: int = int(screen_size.y * GameManager.SCREEN_PERCENTAGE)
	var target_size: Vector2i = Vector2i(new_width, new_height)
	
	# 4. Apply the new size to your application window
	var window: Window = get_window()
	window.size = target_size
	
	# 5. Center the newly sized window perfectly on the monitor
	var target_position: Vector2i = (screen_size - target_size) / 2
	window.position = target_position


## generate menu buttons
func _setup_menu_buttons() -> void:
	var game_names: Array[String] = GameManager.get_game_names()
	
	for game_name_text in game_names:
		var new_button: Button = Button.new()
		new_button.text = game_name_text.to_upper()
		new_button.theme = _BUTTON_THEME
		
		# Add the button and push it to the very top of the container layout
		_button_aligner.add_child(new_button)
		_button_aligner.move_child(new_button, 0)
		
		new_button.pressed.connect(GameManager.start_game.bind(game_name_text))


func _on_exit_button_pressed() -> void:
	get_tree().quit()
"

